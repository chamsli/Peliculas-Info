@model proyectoAPI.Models.Movie

@{
   ViewData["Title"] = Model.title;
}

<div class="detail-container">
   <div class="backdrop" style="background-image: url('https://image.tmdb.org/t/p/original@(Model.backdrop_path)')">
      <div class="overlay"></div>
      <div class="detail-content">
         <img src="https://image.tmdb.org/t/p/w342@(Model.poster_path)" alt="@Model.title">
         <div class="detail-text">
            <h1>@Model.title</h1>
            <p class="tagline">@Model.tagline</p>
            <p><strong>⭐ @Model.vote_average/10</strong> (@Model.vote_count votes)</p>
            <p>📅 @Model.release_date • 🕒 @Model.runtime min</p>
            <p class="genres">
               @foreach (var g in Model.genres)
               {
                  <span class="genre">@g.name</span>
               }
            </p>
            <p class="overview">@Model.overview</p>

            @if (Model.videos.results.Any(v => v.type == "Trailer"))
            {
               var trailer = Model.videos.results.First(v => v.type == "Trailer");
               <a href="https://www.youtube.com/watch?v=@trailer.key" target="_blank" class="btn-trailer">🎬 Watch
                  trailer</a>
               }
               <a href="/Home/Index" class="btn-back">← Back</a>
            </div>
         </div>
      </div>

      <div class="cast-section">
         <h2>Main Cast</h2>
         <div class="cast-list">
            @foreach (var actor in Model.credits.cast.Take(8))
            {
               <div class="cast-card">
                  <img src="https://image.tmdb.org/t/p/w185@(actor.profile_path)" alt="@actor.name">
                  <p><strong>@actor.name</strong><br>@actor.character</p>
               </div>
            }
         </div>
      </div>
   </div>