@model List<proyectoAPI.Models.Movie>

@{
    ViewData["Title"] = "Popular Movies";
}

<header class="hero">
    <h1>🎬 Cinema Discovery</h1>
    <p>Explore the most popular movies, top rated, and trending actors</p>
</header>

<div class="movie-grid">
    @foreach (var movie in Model)
    {
        <div class="movie-card">
            <a href="/Home/Details/@movie.id">
                <img src="https://image.tmdb.org/t/p/w342@(movie.poster_path)" alt="@movie.title" loading="lazy">
                <div class="movie-info">
                    <h3>@movie.title</h3>
                    <p class="year">📅 @(movie.release_date?.Length >= 4 ? movie.release_date.Substring(0,4) : "Upcoming")</p>
                    <div class="rating">⭐ @movie.vote_average.ToString("0.0")</div>
                </div>
            </a>
        </div>
    }
</div>

<!-- Improved pagination -->
<div class="pagination">
    @for (int i = 1; i <= 10; i++)
    {
        <a href="/Home/Index?page=@i" class="page-link">@i</a>
    }
</div>