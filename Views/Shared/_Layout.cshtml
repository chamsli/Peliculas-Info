<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cinema Discovery</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a class="logo" href="/">🎬 CinemaDiscovery</a>
            <div class="nav-links">
                <a href="/Home/Index">Popular</a>
                <a href="/Home/TopRated">Top Rated</a>
                <a href="/Home/Upcoming">Upcoming</a>
                <a href="/Home/Actors">Actors</a>
                <form method="get" action="/Home/Search" class="search-form">
                    <input type="text" name="query" placeholder="Search movie..." />
                    <button type="submit">🔍</button>
                </form>
            </div>
        </div>
    </nav>
    <main class="container">
        @RenderBody()
    </main>
    <footer>
        <p>Data provided by TMDb · MP5 Project · DAW</p>
    </footer>
</body>
</html>